
server {
	root ./www2
	listen 37.59.120.163
	port 9002
	server_name t2
	error_page 404 ./errors/404.html
	error_page 405 ./errors/405.html
	max_body_size 50000
	index acceuil.html

	route / {
		root ./www2
		directory_listing on
		methods GET POST DELETE
	}

	route /api {
		root ./www2/api
		methods GET POST
	}

	route /upload {
		root ./www2/upload
		methods GET POST DELETE
		upload on
		upload_path ./www2/upload
	}

}

